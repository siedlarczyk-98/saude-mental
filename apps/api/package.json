    "db:generate": "kysely-codegen --dialect postgres --out-file src/db/types.ts"
  },
  "dependencies": {
    "@saude-mental/shared": "*",
    "fastify": "^4.27.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "kysely": "^0.27.3",
    "pg": "^8.11.5",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1",
    "@anthropic-ai/sdk": "^0.55.0"
  },
  "devDependencies": {
    "typescript": "*",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.11.0",
    "kysely-codegen": "^0.15.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.4",
    "cross-env": "^7.0.3"
  }
